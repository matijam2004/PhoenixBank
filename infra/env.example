# Environment variables for Docker Compose
# Copy this file to .env and update with your values

# Database name (default: phoenix)
DB_NAME=phoenix

# OpenAI API Key (optional, required for check processing features)
# Leave empty if not using check processing
OPENAI_API_KEY=

# Google OAuth Configuration (REQUIRED for Google login)
# Get these from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-google-client-id-here
GOOGLE_CLIENT_SECRET=your-google-client-secret-here

# Google OAuth Redirect URI
# For Docker production, use: http://localhost/api/auth/google/callback
# For custom domain, use: https://yourdomain.com/api/auth/google/callback
GOOGLE_REDIRECT_URI=http://localhost/api/auth/google/callback

# Frontend URL (used for OAuth redirects)
# For Docker production, use: http://localhost
# For custom domain, use: https://yourdomain.com
FRONTEND_URL=http://localhost

# Frontend API URL (used during build)
# For Docker production with nginx proxy, use: /api (relative path)
# For development, use: http://localhost:8000/api
VITE_API_URL=/api

# Google Client ID for frontend (optional, for Google Sign-In button)
VITE_GOOGLE_CLIENT_ID=your-google-client-id-here

# Google Maps API Key (optional, if using Google Maps features)
VITE_GOOGLE_MAPS_API_KEY=

# JWT Secret (IMPORTANT: Change this in production!)
# Generate a secure random string for production
JWT_SECRET=dev-super-secret-change-me-in-production

# CORS Origins (optional, comma-separated)
# If not set, defaults to localhost URLs
# Example: http://localhost,https://yourdomain.com
CORS_ORIGINS=

