# ============================================================
# Phoenix Bank — Environment Variables
# Copy this file to .env and fill in your values.
# ============================================================

# --- Database ---
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
DB_NAME=phoenix

# --- Auth ---
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-me-to-a-long-random-string
SECURE_COOKIES=false   # Set to true when serving over HTTPS in production

# --- Google OAuth (optional — disables Google login if omitted) ---
# https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI_LOGIN=http://localhost/api/auth/google/callback/login
GOOGLE_REDIRECT_URI_SIGNUP=http://localhost/api/auth/google/callback/signup

# --- URLs ---
FRONTEND_URL=http://localhost          # Set to your Vercel URL in production
VITE_API_BASE_URL=                     # Set to your backend URL in production (e.g. https://api.yourdomain.com)
VITE_API_URL=/api                      # Leave as /api when using nginx proxy
VITE_GOOGLE_CLIENT_ID=                 # Same as GOOGLE_CLIENT_ID

# --- Email / SMTP (optional — disables email verification if omitted) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=                         # Gmail: use an App Password, not your account password
FROM_EMAIL=

# --- CORS ---
# Comma-separated list of allowed origins.
# Leave empty to allow all localhost variants (dev only).
# Production example: https://phoenixbank.vercel.app
CORS_ORIGINS=

# --- Optional features ---
OPENAI_API_KEY=                        # Enables GPT-4 Vision for check OCR
VITE_GOOGLE_MAPS_API_KEY=              # Enables Google Maps on ATM locator page
